#!/usr/bin/env bash
# ~/dotfiles/bin/tp

set -euo pipefail

CODE_DIR="${CODE_DIR:-$HOME/code}"

project_path="$(
  fd . "$CODE_DIR" \
    --type d \
    --max-depth 2 \
    --exclude dist.go \
    --has .git |
    fzf
)"

[ -z "${project_path:-}" ] && exit 0

session_name="$(basename "$project_path" | tr '.:' '__')"

if tmux has-session -t "$session_name" 2>/dev/null; then
  tmux switch-client -t "$session_name" 2>/dev/null || tmux attach -t "$session_name"
else
  tmux new-session -d -s "$session_name" -c "$project_path" -n editor
  tmux send-keys -t "$session_name:1" "cd '$project_path' && nvim ." C-m

  tmux new-window -t "$session_name" -c "$project_path" -n shell
  tmux new-window -t "$session_name" -c "$project_path" -n logs

  tmux select-window -t "$session_name:1"
  tmux switch-client -t "$session_name" 2>/dev/null || tmux attach -t "$session_name"
fi
