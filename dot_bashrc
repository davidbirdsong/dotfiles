set -o vi

source_files=(
  ~/.go_env
  ~/.githhub_tokens
  ~/.gcloud
  ~/.aws_aliases
  ~/.history.rc
  ~/.bash_completion.rc
  ~/.completions/chezmoi
  ~/.kube_switcher
  ~/.git_ps1.rc
  ~/.git_spice_ps1.rc
  ~/.pickers.rc
  ~/.cargo/env

)
for f in "${source_files[@]}"; do
  [[ -f $f ]] || continue
  . $f
done

